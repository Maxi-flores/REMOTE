{
  "name": "Cloud Desktop with Remmina",
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "vscode"
    },
    "ghcr.io/tailscale/codespace/tailscale:1": {}
  },
  "forwardPorts": [6080],
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y remmina remmina-plugin-rdp"
}
